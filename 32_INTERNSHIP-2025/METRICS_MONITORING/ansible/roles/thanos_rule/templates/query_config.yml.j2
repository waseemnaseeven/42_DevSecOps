- http_config:
    basic_auth:
      username: ""
      password: ""
      password_file: ""
    bearer_token: ""
    bearer_token_file: ""
    proxy_url: ""
    tls_config:
      ca_file: "{{ thanos_ca_file }}"
      cert_file: "{{ thanos_crt_client_http }}"
      key_file: "{{ thanos_key_client_http }}"
      server_name: ""
      insecure_skip_verify: false
  static_configs:
    - {{ thanos_query_private_ip }}:9090
    - {{ thanos_query2_private_ip }}:9090
    - {{ thanos_query3_private_ip }}:9090
  file_sd_configs:
  - files: 
    - "/etc/thanos/sd.yml"
    refresh_interval: 2m
  scheme: https
  path_prefix: ""
  grpc_config:
    endpoint_addresses: []