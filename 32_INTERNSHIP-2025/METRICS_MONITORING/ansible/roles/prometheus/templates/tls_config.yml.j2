{% if prometheus_tls_server_enabled | default('false') %}
tls_server_config:
  cert_file: {{ prometheus_tls_server.cert_file | quote }}
  key_file: {{ prometheus_tls_server.key_file | quote }}
{% if prometheus_tls_client_enabled | default('false') %}
  client_ca_file: {{ prometheus_tls_client.ca_file | quote }}
  client_auth_type: RequireAndVerifyClientCert
  client_allowed_sans: 
    - "grafanaclient"
    - "grafanaclient2"
    - "prometheusclient"
    - "prometheusclient2"
    - "prometheusclient3"
    - "wnn143"
    - "sidecarA"
    - "sidecarB"
    - "sidecarC"
  {% endif %}
{% endif %}