[global_config]
  suppress_multiple_term_dialog = True
[keybindings]
[profiles]
  [[default]]
    cursor_fg_color = "#000000"
    cursor_bg_color = "#aaaaaa"
    title_inactive_bg_color = "#4C566A"
    title_inactive_fg_color = "#D8DEE9"
    title_receive_bg_color = "#8FBCBB"
    title_receive_fg_color = "#2E3440"
    title_transmit_bg_color = "#88C0D0"
    title_transmit_fg_color = "#2E3440"
    title_use_system_font = False
    title_font = Hack Nerd Font 14
    scrollback_infinite = True
    font = Hack Nerd Font 12
    use_system_font = False
    background_color = "#2E3440"
    cursor_color = "#D8DEE9"
    foreground_color = "#D8DEE9"
    palette =    "#3B4252:#BF616A:#A3BE8C:#EBCB8B:#81A1C1:#B48EAD:#88C0D0:#E5E9F0:#4C566A:#BF616A:#A3BE8C:#EBCB8B:#81A1C1:#B48EAD:#8FBCBB:#ECEFF4"
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
[plugins]
